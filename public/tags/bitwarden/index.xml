&lt;li&gt;Teams Organization&lt;/li&gt;
&lt;!-- /wp:list-item --&gt;
&lt;!-- wp:list-item --&gt;
&lt;li&gt;Enterprise Organization&lt;/li&gt;
&lt;!-- /wp:list-item --&gt;
&lt;!-- wp:list-item --&gt;
&lt;li&gt;Custom deployment options&lt;/li&gt;
&lt;!-- /wp:list-item --&gt;&lt;/ul&gt;
&lt;!-- /wp:list --&gt;
&lt;h2&gt;Getting Started with Bitwarden&lt;/h2&gt;&lt;span class=&#34;hx-absolute -hx-mt-20&#34; id=&#34;getting-started-with-bitwardenh2&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#getting-started-with-bitwardenh2&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h2&gt;&lt;!-- /wp:heading --&gt;
&lt;!-- wp:heading {&#34;level&#34;:3} --&gt;
