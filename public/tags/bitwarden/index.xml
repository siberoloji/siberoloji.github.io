&lt;!-- /wp:list --&gt;
&lt;!-- wp:heading {&#34;level&#34;:3} --&gt;
&lt;h3&gt;Best Practices for Usage&lt;/h3&gt;&lt;span class=&#34;hx-absolute -hx-mt-20&#34; id=&#34;best-practices-for-usageh3&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#best-practices-for-usageh3&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;!-- /wp:heading --&gt;
&lt;!-- wp:list {&#34;ordered&#34;:true} --&gt;
&lt;ol class=&#34;wp-block-list&#34;&gt;&lt;!-- wp:list-item --&gt;
&lt;li&gt;&lt;strong&gt;Master Password Security&lt;/strong&gt;&lt;/li&gt;
&lt;!-- /wp:list-item --&gt;&lt;/ol&gt;
&lt;!-- /wp:list --&gt;
&lt;!-- wp:list --&gt;
&lt;ul class=&#34;wp-block-list&#34;&gt;&lt;!-- wp:list-item --&gt;
&lt;li&gt;Create a strong, memorable master password&lt;/li&gt;
&lt;!-- /wp:list-item --&gt;
&lt;!-- wp:list-item --&gt;
&lt;li&gt;Never share your master password&lt;/li&gt;
&lt;!-- /wp:list-item --&gt;
&lt;!-- wp:list-item --&gt;
